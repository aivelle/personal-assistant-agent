{
  "name": "Daily Digest",
  "description": "Summarize today's completed tasks, delays, and preview tomorrow's key items.",
  "source": {
    "type": "notion",
    "databases": {
      "tasks": {
        "completed_on": "today"
      },
      "projects": {
        "filter": {
          "status": ["blocked", "waiting", "in progress"]
        }
      }
    }
  },
  "preview": {
    "tomorrow_tasks": {
      "due": "tomorrow",
      "limit": 3
    }
  },
  "action": {
    "type": "summary",
    "format": "sectioned",
    "sections": ["Completed Today", "Issues", "Tomorrow Preview"],
    "delivery": {
      "method": "preview",
      "channel": "chat"
    }
  }
}
