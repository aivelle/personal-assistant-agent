{
  "name": "Idea to Summary",
  "description": "Summarize today's new ideas and present a preview for user confirmation.",
  "source": {
    "type": "notion",
    "database": "idea_spark",
    "filter": {
      "date": "today",
      "summary": "is_empty"
    }
  },
  "action": {
    "type": "summarize",
    "length": "short",
    "delivery": {
      "method": "preview",
      "channel": "chat",
      "options": ["save", "needs development", "delete"]
    }
  }
}
