{
  "name": "Appointment to Availability",
  "description": "Convert Google Appointment to available slots and sync with Notion.",
  "trigger": {
    "type": "daily",
    "time": "07:00"
  },
  "source": {
    "type": "google_appointments",
    "calendar": "default"
  },
  "action": {
    "type": "sync_to_notion",
    "notion_database": "availability",
    "delivery": {
      "method": "log",
      "channel": "system"
    }
  }
}
