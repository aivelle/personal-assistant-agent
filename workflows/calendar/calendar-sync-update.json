{
  "name": "Calendar Sync Update",
  "description": "Sync changes across Google Calendar and Notion schedule.",
  "trigger": {
    "type": "event_change"
  },
  "source": {
    "type": "calendar",
    "watch": ["google", "notion"]
  },
  "action": {
    "type": "sync_update",
    "delivery": {
      "method": "log",
      "channel": "system"
    }
  }
}
