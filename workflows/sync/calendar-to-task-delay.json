{
  "name": "Calendar to Task Delay",
  "description": "Detect if tasks are delayed compared to Google Calendar.",
  "trigger": {
    "type": "daily",
    "time": "18:00"
  },
  "source": {
    "type": "google_calendar",
    "range": "today"
  },
  "action": {
    "type": "cross_check",
    "compare_with": "notion.tasks",
    "logic": "due_date_slip",
    "delivery": {
      "method": "preview",
      "channel": "chat"
    }
  }
}
