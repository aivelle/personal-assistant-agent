{
  "name": "Obsidian to Notion Sync",
  "description": "Sync newly tagged Obsidian notes to Notion project pages.",
  "trigger": {
    "type": "manual"
  },
  "source": {
    "type": "obsidian",
    "folder": "2.Sprout",
    "tag": "export"
  },
  "action": {
    "type": "create_page",
    "target": "notion.projects",
    "properties": {
      "title": "{{note_title}}",
      "content": "{{note_body}}"
    }
  }
}
