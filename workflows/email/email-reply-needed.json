{
  "name": "Email Reply Needed",
  "description": "Detect emails that need a reply and notify the user.",
  "trigger": {
    "type": "email_received",
    "filter": {
      "body_keywords": ["please reply", "waiting for your response", "need your input"]
    }
  },
  "source": {
    "type": "gmail",
    "fields": ["subject", "body", "from", "thread_id"]
  },
  "action": {
    "type": "notify",
    "channel": "chat",
    "priority": "medium",
    "message_template": "📨 Reply needed for email from {{from}}: '{{subject}}'"
  }
}
