{
  "name": "Email Confirm and Update",
  "description": "Parses confirmation emails and updates Google Calendar if needed.",
  "trigger": {
    "type": "on_email_received"
  },
  "source": {
    "type": "gmail",
    "fields": ["subject", "body", "from"]
  },
  "action": {
    "type": "calendar_check",
    "calendar": "google_calendar",
    "follow_up": {
      "if_conflict": "suggest_alternative",
      "if_available": "confirm_and_add"
    },
    "delivery": {
      "method": "chat",
      "channel": "calendar"
    }
  }
}
