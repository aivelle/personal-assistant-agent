{
  "name": "Email to Notion",
  "description": "Save important incoming emails to Notion for later processing.",
  "trigger": {
    "type": "email_received",
    "filter": {
      "labels": ["important", "to-process"]
    }
  },
  "source": {
    "type": "gmail",
    "fields": ["from", "subject", "body", "received_at"]
  },
  "action": {
    "type": "notion_create",
    "database": "inbox",
    "properties": {
      "From": "{{from}}",
      "Subject": "{{subject}}",
      "Body": "{{body}}",
      "Received At": "{{received_at}}"
    }
  }
}
