{
  "name": "Email Priority Alert",
  "description": "Alert user when high-priority emails are received.",
  "trigger": {
    "type": "email_received",
    "filter": {
      "from": ["ceo@company.com", "*@boss.com"],
      "subject_keywords": ["urgent", "important", "asap"]
    }
  },
  "source": {
    "type": "gmail",
    "fields": ["subject", "body", "from"]
  },
  "action": {
    "type": "notify",
    "channel": "chat",
    "priority": "high",
    "message_template": "📬 High-priority email from {{from}}: '{{subject}}'"
  }
}
