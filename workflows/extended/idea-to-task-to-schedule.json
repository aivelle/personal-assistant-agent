{
    "name": "idea-to-task-to-schedule",
    "description": "Converts a captured idea into a task, and immediately schedules it based on availability.",
    "trigger": "notion.idea.new",
    "inputs": {
      "idea_text": "string",
      "notion_idea_id": "notion_page_id"
    },
    "steps": [
      {
        "action": "classify_idea_priority"
      },
      {
        "action": "convert_to_task",
        "parameters": {
          "status": "To Do",
          "linked_project": true
        }
      },
      {
        "action": "find_available_time_slot",
        "constraints": {
          "min_block": "30m",
          "max_block": "2h"
        }
      },
      {
        "action": "schedule_task",
        "platforms": ["notion", "google_calendar"]
      }
    ],
    "outputs": {
      "task_created": true,
      "scheduled_time": "timestamp"
    }
  }
  